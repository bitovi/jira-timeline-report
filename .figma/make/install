#!/bin/bash
# Installs project dependencies and ensures a .env exists. Runs every session.
set -e

cd "$(dirname "$0")/../.."

if [ ! -f .env ]; then
  echo "No .env found — creating one from .env.example"
  cp .env.example .env
  echo "Created .env (Jira OAuth credentials are blank; the UI still loads without them)"
fi

echo "Running npm install"
npm install
echo "Dependencies installed"
