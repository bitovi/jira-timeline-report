#!/bin/bash
# Waits for the Vite dev server (the browser-facing app) to serve requests.
set -e

HEALTHCHECK_URL='http://localhost:5173/'
MAX_WAIT=180
INTERVAL=2
ELAPSED=0

echo "Waiting for development server to be ready at $HEALTHCHECK_URL"

while [ $ELAPSED -lt $MAX_WAIT ]; do
  if curl -sf "$HEALTHCHECK_URL" >/dev/null 2>&1; then
    echo "Dev server is up"
    exit 0
  fi
  sleep $INTERVAL
  ELAPSED=$((ELAPSED + INTERVAL))
done

echo "Error: Dev server did not start within ${MAX_WAIT}s"
exit 1
