#!/bin/bash
# Installs system-level dependencies (language toolchain). Runs once per repo,
# cached thereafter. This project only needs Node.js (see .nvmrc: v22.9.0).
set -e

echo "Checking system dependencies..."

REQUIRED_NODE_MAJOR=22

NODE_VERSION="$(node --version 2>/dev/null || echo "none")"
if [[ "$NODE_VERSION" == "none" ]]; then
  echo "Node.js not found — installing via Homebrew"
  brew install node@22
else
  CURRENT_MAJOR="$(echo "$NODE_VERSION" | sed 's/^v//' | cut -d. -f1)"
  if [[ "$CURRENT_MAJOR" -lt "$REQUIRED_NODE_MAJOR" ]]; then
    echo "Node $NODE_VERSION is older than required v${REQUIRED_NODE_MAJOR} — installing node@22"
    brew install node@22
  else
    echo "Node $NODE_VERSION OK"
  fi
fi

echo "System dependencies verified."
