# Copy this file to `.env` (run `npm run setup` to do this automatically).
#
# Only two values are REQUIRED to run the full app with real Jira login:
#   VITE_JIRA_CLIENT_ID and JIRA_CLIENT_SECRET (see below).
# If you only need to work on UI with mock data, run `npm run storybook`
# instead — no credentials required.

# Port the local Express auth server listens on.
PORT=3000

# REQUIRED. OAuth 2.0 client ID for the Jira app.
# We use a SHARED dev OAuth app — if this is blank, ask in the team room for
# the dev credentials (client id + secret). You can also create your own app at
# https://developer.atlassian.com/console/myapps/ (see CONTRIBUTING.md).
VITE_JIRA_CLIENT_ID=

# App key used for the Jira Connect plugin build. The default is fine for local.
VITE_JIRA_APP_KEY=bitovi.timeline-report.local

# OAuth scopes requested during login. Defaults are correct for local dev.
VITE_JIRA_SCOPE="read:jira-work write:jira-work offline_access"

# OAuth redirect URL. Must match the callback configured on the OAuth app.
VITE_JIRA_CALLBACK_URL=http://localhost:5173/oauth-callback

# Jira REST API base URL. Leave as-is unless you know you need a different host.
VITE_JIRA_API_URL=https://api.atlassian.com/ex/jira

# URL of the local Express auth server (token exchange). Matches PORT above.
VITE_AUTH_SERVER_URL=http://localhost:3000

# REQUIRED. OAuth 2.0 client secret paired with VITE_JIRA_CLIENT_ID above.
# If blank, ask in the team room for the shared dev credentials.
JIRA_CLIENT_SECRET=
